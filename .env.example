PORT=3000
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=water-platform-server
MQTT_UPLINK_TOPIC=devices/+/up
MQTT_STATUS_TOPIC=devices/+/status
MQTT_COMMAND_TOPIC=devices/+/command
MQTT_DOWNLINK_TOPIC_TEMPLATE=devices/{device_id}/down
DB_PATH=./data/water_quality.db
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
VIDEO_ENABLED=true
VIDEO_STREAM_PREFIX=live
VIDEO_HEARTBEAT_OFFLINE_MS=15000
VIDEO_PUBLIC_RTSP_BASE_URL=rtsp://127.0.0.1:8554
VIDEO_PUBLIC_WEBRTC_BASE_URL=/mtx-webrtc
VIDEO_PUBLIC_HLS_BASE_URL=/mtx-hls
